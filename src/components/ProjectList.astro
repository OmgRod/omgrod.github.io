---
import { getCollection } from 'astro:content';
import { Tabs, TabItem, Badge } from '@astrojs/starlight/components';

const entries = await getCollection('docs');
const tabLabels = ['All', 'Geode Mods', 'Websites', 'Programs', 'Misc.'] as const;
const canonicalTagByTab = {
	'Geode Mods': 'geode-mod',
	Websites: 'website',
	Programs: 'program',
} as const;
const knownTags = new Set(['geode-mod', 'website', 'program']);

const normalizeTag = (value: string) => value.trim().toLowerCase();

const resolveProjectHref = (entry: (typeof entries)[number]) => {
	const rawPath = entry.slug ?? entry.id;
	const normalizedPath = rawPath
		.replace(/\.(md|mdx)$/i, '')
		.replace(/\/index$/i, '')
		.replace(/^\/+|\/+$/g, '');

	return `/${normalizedPath}/`;
};

const toCanonicalTag = (value: string) => {
	const normalized = normalizeTag(value);

	if (normalized === 'geode-mod' || normalized === 'geodemod' || normalized === 'geode mods' || normalized === 'geode_mod') {
		return 'geode-mod';
	}

	if (normalized === 'website' || normalized === 'websites') {
		return 'website';
	}

	if (normalized === 'program' || normalized === 'programs') {
		return 'program';
	}

	return normalized;
};

const projects = entries
	.filter((entry) => entry.id.startsWith('projects/'))
	.sort((left, right) => {
		const leftId = left.data.projectId ?? left.id.replace(/^projects\//, '');
		const rightId = right.data.projectId ?? right.id.replace(/^projects\//, '');

		if (leftId && rightId && leftId !== rightId) {
			return leftId.localeCompare(rightId);
		}

		return left.data.title.localeCompare(right.data.title);
	})
	.map((entry) => ({
		title: entry.data.title,
		description: entry.data.description,
		projectId: entry.data.projectId ?? entry.id.replace(/^projects\//, ''),
		tags: (entry.data.projectTags ?? []).map((tag) => toCanonicalTag(tag)),
		badges: (entry.data.projectBadges ?? []).map((b) =>
			typeof b === 'string' ? { text: b, variant: 'default' as const } : b
		),
		thumbnail: entry.data.projectThumbnail,
		icon: entry.data.projectIcon,
		href: resolveProjectHref(entry),
	}));

const projectsForTab = (label: (typeof tabLabels)[number]) => {
	if (label === 'All') {
		return projects;
	}

	if (label === 'Misc.') {
		return projects.filter((project) => !project.tags.some((tag) => knownTags.has(tag)));
	}

	const expectedTag = canonicalTagByTab[label];
	return projects.filter((project) => project.tags.includes(expectedTag));
};
---

<section class="project-list" aria-label="Projects">
	<Tabs>
		{tabLabels.map((label) => {
			const tabProjects = projectsForTab(label);

			return (
				<TabItem label={label}>
					{tabProjects.length === 0 ? (
						<p class="empty-state">
							{label === 'All'
								? 'No projects yet.'
								: `No projects in ${label} yet.`}
						</p>
					) : (
						<ul class="project-items">
							{tabProjects.map((project) => (
								<li>
									<a class="project-item" href={project.href}>
										{(project.thumbnail || project.icon) && (
											<div class="media" aria-hidden="true">
												{project.thumbnail ? (
													<img src={project.thumbnail} alt="" loading="lazy" decoding="async" />
												) : project.icon?.endsWith('.svg') || project.icon?.endsWith('.png') || project.icon?.endsWith('.jpg') || project.icon?.endsWith('.jpeg') || project.icon?.endsWith('.webp') ? (
													<img src={project.icon} alt="" loading="lazy" decoding="async" />
												) : (
													<span>{project.icon}</span>
												)}
											</div>
										)}
										<div class="content">
											<p class="name">{project.title}</p>
										{project.description && <p class="description">{project.description}</p>}
										{project.badges.length > 0 && (
											<div class="badges">
												{project.badges.map((badge) => (
													<Badge text={badge.text} variant={badge.variant} />
												))}
											</div>
										)}
										{project.projectId && <p class="project-id">ID: {project.projectId}</p>}
										</div>
									</a>
								</li>
							))}
						</ul>
					)}
				</TabItem>
			);
		})}
	</Tabs>
</section>

<style>
	@layer starlight.components {
		.project-items {
			list-style: none;
			padding: 0;
			margin: 0;
			display: grid;
			gap: 0.35rem;
		}

		.project-item {
			display: flex;
			align-items: flex-start;
			gap: 0.6rem;
			padding: 0.45rem 0.75rem;
			border: 1px solid var(--sl-color-gray-5);
			border-radius: 0.75rem;
			background: var(--sl-color-bg-nav);
			text-decoration: none;
			transition: border-color 120ms ease, background-color 120ms ease;
		}

		.project-item:hover,
		.project-item:focus-visible {
			border-color: var(--sl-color-accent);
			background: var(--sl-color-bg-sidebar);
		}

		.content {
			min-width: 0;
			flex: 1;
			display: grid;
			gap: 0;
		}

		.name {
			margin: 0;
			font-weight: 600;
			line-height: 1;
			color: var(--sl-color-text);
		}

		.description {
			margin: 0;
			font-size: 0.92rem;
			line-height: 1;
			color: var(--sl-color-gray-2);
		}

		.badges {
			display: flex;
			flex-wrap: wrap;
			gap: 0.2rem;
			margin-top: 0;
		}

		.project-id {
			margin: 0;
			font-size: 0.78rem;
			line-height: 1;
			color: var(--sl-color-gray-3);
		}

		.media {
			width: 3.25rem;
			height: 3.25rem;
			flex-shrink: 0;
			display: grid;
			place-items: center;
			align-self: center;
			border-radius: 0.5rem;
			overflow: hidden;
			color: var(--sl-color-text-accent);
			font-size: 1.25rem;
			line-height: 1;
		}

		.media img {
			width: 100%;
			height: 100%;
			object-fit: contain;
			object-position: center;
		}

		.media span {
			display: grid;
			place-items: center;
			width: 100%;
			height: 100%;
		}

		.empty-state {
			margin: 0;
			color: var(--sl-color-gray-2);
		}
	}
</style>
