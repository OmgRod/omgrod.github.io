---
import Icon from './Icon.astro';
import type { StarlightIcon } from './Icons';

interface Props {
	icon?: StarlightIcon | string;
	title: string;
    color: string; // Can be a predefined color or a hex code
    iconColor?: string; // Optional prop for icon-specific color
}

const { icon, title, color, iconColor } = Astro.props;
const isImagePath = typeof icon === 'string' && (icon.endsWith('.svg') || icon.endsWith('.png'));
const resolvedIconColor = iconColor || color || 'currentColor'; // Default to color or currentColor for SVG
---

<article class="card sl-flex">
	<p class="title sl-flex">
		{icon && !isImagePath && <Icon name={icon as StarlightIcon} class="icon" color={resolvedIconColor} size="1.333em" />}
		{isImagePath && <img src={icon} alt="icon" class="icon" style={`width: 1.333em; height: 1.333em; object-fit: contain; border: 1px solid ${color}; background-color: transparent;`} />}
		<span set:html={title} />
	</p>
	<div class="body"><slot /></div>
</article>

<style>
	@layer starlight.components {
		.card {
			--sl-card-border: var(--sl-color-purple);
			--sl-card-bg: var(--sl-color-purple-low);
			border: 1px solid var(--sl-color-gray-5);
			background-color: var(--sl-color-black);
			padding: clamp(1rem, calc(0.125rem + 3vw), 2.5rem);
			flex-direction: column;
			gap: clamp(0.5rem, calc(0.125rem + 1vw), 1rem);
        }

		.title {
			font-weight: 600;
			font-size: var(--sl-text-h4);
			color: var(--sl-color-white);
			line-height: var(--sl-line-height-headings);
			gap: 1rem;
			align-items: center;
		}
		.card .icon {
			padding: 0.2em;
			border-radius: 0.25rem;
			background-color: transparent; /* Ensure fill color is transparent */
			filter: none; /* Remove invert filter to fix color inversion */
		}
	}
</style>